<h1>Books</h1>

<%= link_to "Add Book", new_book_path, class: "btn btn-primary" %>

<table border="1" cellpadding="10">
  <thead>
    <tr>
      <th>Title</th>
      <th>Author</th>
      <th>Genre</th>
      <th>Price</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= book.title %></td>
        <td><%= book.author %></td>
        <td><%= book.genre %></td>
        <td>₹<%= book.price %></td>

        <td>
          <%= link_to "Show", book_path(book) %>
          <%= link_to "Edit", edit_book_path(book) %>
          <%= link_to "Delete", book_path(book), method: :delete, data: { confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
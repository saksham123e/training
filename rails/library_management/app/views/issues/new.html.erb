<h1>Issue Book</h1>

<%= form_with model: @issue do |f| %>

  <p>User</p>
  <%= f.collection_select :user_id, @users, :id, :name %>

  <p>Book</p>

  <% if @selected_book %>
    <%= f.hidden_field :book_id, value: @selected_book.id %>
    <p><%= @selected_book.title %></p>
  <% else %>
    <%= f.collection_select :book_id, @books, :id, :title %>
  <% end %>

  <br>
  <%= f.submit "Issue Book" %>

<% end %>
<div class="container">
  <div class="hero-card">
    <h1>Rails Social Login</h1>
    <p>Secure authentication with Devise and Facebook OAuth</p>

    <% if user_signed_in? %>
      <h3>Welcome <%= current_user.email %></h3>
      <%= link_to "Go to Dashboard", dashboard_path, class: "btn" %>
    <% else %>
      <%= link_to "Login", new_user_session_path, class: "btn" %>
      <%= link_to "Signup", new_user_registration_path, class: "btn" %>

      <%= button_to "Continue with Facebook",
          user_facebook_omniauth_authorize_path,
          method: :post,
          data: { turbo: false },
          class: "btn" %>
    <% end %>
  </div>
</div>
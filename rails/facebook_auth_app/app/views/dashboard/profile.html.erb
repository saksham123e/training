<div class="container">
  <div class="profile-card">
    <h1>User Profile</h1>

    <div class="info-box">
      <p><strong>Email:</strong> <%= current_user.email %></p>
      <p><strong>Provider:</strong> <%= current_user.provider || "Devise Email" %></p>
      <p><strong>UID:</strong> <%= current_user.uid || "N/A" %></p>
      <p><strong>Created:</strong> <%= current_user.created_at.strftime("%d %B %Y") %></p>
    </div>

    <%= link_to "Back to Dashboard", dashboard_path, class: "btn" %>
  </div>
</div>
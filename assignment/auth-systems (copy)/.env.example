APP_NAME=Form AI Auth
APP_ENV=development
FRONTEND_BASE_URL=http://127.0.0.1:8000
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
RESET_TOKEN_EXPIRE_MINUTES=30

<div class="container">
  <div class="dashboard-card">
    <h1>Dashboard</h1>
    <p>Authentication completed successfully ✅</p>

    <div class="info-box">
      <p><strong>Email:</strong> <%= current_user.email %></p>
      <p><strong>Provider:</strong> <%= current_user.provider || "Email Login" %></p>
      <p><strong>Status:</strong> Logged In</p>
    </div>

    <%= link_to "View Profile", profile_path, class: "btn" %>
    <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn" %>
  </div>
</div>
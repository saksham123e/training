<div class="page-header">
  <div>
    <p class="eyebrow">Import Details</p>
    <h1><%= @import.file_name %></h1>
    <p class="subtitle">Detailed status and processing summary.</p>
  </div>

  <%= link_to "Back", imports_path, class: "btn" %>
</div>

<div class="detail-grid">
  <div class="card">
    <h2>Status</h2>
    <span class="badge large <%= @import.status %>"><%= @import.status %></span>

    <div class="progress-bar">
      <% percent = @import.total_rows.to_i.zero? ? 0 : ((@import.processed_rows.to_f / @import.total_rows) * 100).round %>
      <div style="width: <%= percent %>%"></div>
    </div>

    <p><%= @import.progress_text %> processed</p>
  </div>

  <div class="card summary-card">
    <div>
      <span>Total Rows</span>
      <strong><%= @import.total_rows %></strong>
    </div>

    <div>
      <span>Successful</span>
      <strong><%= @import.successful_rows %></strong>
    </div>

    <div>
      <span>Failed</span>
      <strong><%= @import.failed_rows %></strong>
    </div>
  </div>
</div>

<div class="card">
  <h2>Error Report</h2>

  <% if @import.failed_rows.to_i > 0 %>
    <p>Some rows failed validation. Download the CSV report to review errors.</p>
    <%= link_to "Download Error Report", error_report_import_path(@import), class: "btn primary" %>
  <% else %>
    <p>No failed rows found.</p>
  <% end %>
</div>
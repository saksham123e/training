<div class="page-header">
  <div>
    <p class="eyebrow">Dashboard</p>
    <h1>Import History</h1>
    <p class="subtitle">Track CSV imports, progress, success count and failed records.</p>
  </div>

  <%= link_to "New CSV Import", new_import_path, class: "btn primary" %>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <span>Total Imports</span>
    <strong><%= @imports.count %></strong>
  </div>

  <div class="stat-card">
    <span>Completed</span>
    <strong><%= @imports.where(status: "completed").count %></strong>
  </div>

  <div class="stat-card">
    <span>Processing</span>
    <strong><%= @imports.where(status: "processing").count %></strong>
  </div>

  <div class="stat-card">
    <span>Failed</span>
    <strong><%= @imports.where(status: "failed").count %></strong>
  </div>
</div>

<div class="card">
  <table class="imports-table">
    <thead>
      <tr>
        <th>File Name</th>
        <th>Status</th>
        <th>Total</th>
        <th>Success</th>
        <th>Failed</th>
        <th>Progress</th>
        <th>Uploaded At</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <% @imports.each do |import| %>
        <tr>
          <td><strong><%= import.file_name %></strong></td>
          <td>
            <span class="badge <%= import.status %>"><%= import.status %></span>
          </td>
          <td><%= import.total_rows %></td>
          <td><%= import.successful_rows %></td>
          <td><%= import.failed_rows %></td>
          <td><%= import.progress_text %></td>
          <td><%= import.created_at.strftime("%d %b %Y, %I:%M %p") %></td>
          <td>
            <%= link_to "View", import_path(import), class: "btn small" %>

            <%= button_to "Delete",
                import_path(import),
                method: :delete,
                class: "btn small danger",
                form: { data: { turbo_confirm: "Are you sure you want to delete this import?" } } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
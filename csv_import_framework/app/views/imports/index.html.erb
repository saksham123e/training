<h1>Import History</h1>

<%= link_to "New CSV Import", new_import_path %>

<br><br>

<table border="1" cellpadding="8">
  <tr>
    <th>File Name</th>
    <th>Status</th>
    <th>Total Rows</th>
    <th>Successful Rows</th>
    <th>Failed Rows</th>
    <th>Processed Rows</th>
    <th>Uploaded At</th>
    <th>Action</th>
  </tr>

  <% @imports.each do |import| %>
    <tr>
      <td><%= import.file_name %></td>
      <td><%= import.status %></td>
      <td><%= import.total_rows %></td>
      <td><%= import.successful_rows %></td>
      <td><%= import.failed_rows %></td>
      <td><%= import.processed_rows %></td>
      <td><%= import.created_at.strftime("%d %b %Y %I:%M %p") %></td>
      <td><%= link_to "View", import_path(import) %></td>
    </tr>
  <% end %>
</table>
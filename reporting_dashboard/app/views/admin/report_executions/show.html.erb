<h1>Report Execution Details</h1>

<p>
  <strong>Report Name:</strong>
  <%= @report_execution.report_name %>
</p>

<p>
  <strong>Status:</strong>
  <%= @report_execution.status %>
</p>

<p>
  <strong>Records Processed:</strong>
  <%= @report_execution.records_processed %>
</p>

<p>
  <strong>Execution Time:</strong>
  <%= @report_execution.execution_time %> seconds
</p>

<p>
  <strong>Error Message:</strong>
  <%= @report_execution.error_message.presence || "No Errors" %>
</p>

<p>
  <strong>Executed At:</strong>
  <%= @report_execution.executed_at.strftime("%b %d, %Y %I:%M %p") %>
</p>

<%= link_to "Back to Dashboard", admin_dashboard_path %>
<h1 class="dashboard-title">Reporting Dashboard</h1>

<div class="cards">
  <div class="card">
    <h3>Total Reports Generated</h3>
    <p><%= @total_reports %></p>
  </div>

  <div class="card">
    <h3>Failed Reports</h3>
    <p><%= @failed_reports %></p>
  </div>

  <div class="card">
    <h3>Success Rate</h3>
    <p><%= @success_rate %>%</p>
  </div>

  <div class="card">
    <h3>Average Processing Time</h3>
    <p><%= @average_processing_time %>s</p>
  </div>

  <div class="card">
    <h3>Last Report Run</h3>
    <% if @last_report.present? %>
      <p><%= @last_report.report_name %></p>
      <small><%= @last_report.executed_at.strftime("%b %d, %Y %I:%M %p") %></small>
    <% else %>
      <p>No reports</p>
    <% end %>
  </div>
</div>

<div class="section">
  <h2>Reports Generated Per Day</h2>
  <%= line_chart @reports_per_day %>
</div>

<div class="section">
  <h2>Report Status Distribution</h2>
  <%= pie_chart @status_distribution %>
</div>

<div class="section">
  <h2>Report Types</h2>
  <%= bar_chart @report_types %>
</div>

<div class="section">
  <h2>Average Processing Time Trend</h2>
  <%= line_chart @avg_processing_time_trend %>
</div>

<div class="section">
  <h2>Execution History</h2>

  <%= form_with url: admin_dashboard_path, method: :get, local: true, class: "filter-form" do %>
    <%= text_field_tag :search, params[:search], placeholder: "Search report name" %>

    <%= select_tag :sort,
      options_for_select([
        ["Run Date", "executed_at"],
        ["Processing Time", "execution_time"],
        ["Records Processed", "records_processed"]
      ], params[:sort]) %>

    <%= submit_tag "Search" %>

    <div class="status-buttons">
      <%= link_to "All", admin_dashboard_path, class: "status-btn" %>
      <%= link_to "Completed", admin_dashboard_path(status: "completed"), class: "status-btn completed-btn" %>
      <%= link_to "Failed", admin_dashboard_path(status: "failed"), class: "status-btn failed-btn" %>
      <%= link_to "Processing", admin_dashboard_path(status: "processing"), class: "status-btn processing-btn" %>
      <%= link_to "Pending", admin_dashboard_path(status: "pending"), class: "status-btn pending-btn" %>

      <%= link_to "Export CSV",
          admin_dashboard_path(request.query_parameters.merge(format: :csv)),
          class: "export-btn" %>
    </div>
  <% end %>

  <table>
    <thead>
      <tr>
        <th>Report Name</th>
        <th>Status</th>
        <th>Records</th>
        <th>Duration</th>
        <th>Run Date</th>
      </tr>
    </thead>

    <tbody>
      <% @executions.each do |execution| %>
        <tr>
          <td><%= link_to execution.report_name, admin_report_execution_path(execution) %></td>
          <td>
            <span class="badge <%= execution.status %>">
              <%= execution.status.capitalize %>
            </span>
          </td>
          <td><%= execution.records_processed %></td>
          <td><%= execution.execution_time %>s</td>
          <td><%= execution.executed_at.strftime("%b %d, %Y %I:%M %p") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= paginate @executions %>
</div>